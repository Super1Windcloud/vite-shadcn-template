{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "tailwindCSS.experimental.classRegex": [
    "className:\\s*\"([^\"]*)\"",
    "className:\\s*'([^']*)'",
    "tdClassName:\\s*\"([^\"]*)\"",
    "tdClassName:\\s*'([^']*)'",
    "thClassName:\\s*\"([^\"]*)\"",
    "thClassName:\\s*'([^']*)'"
  ],
  "tailwindCSS.classFunctions": ["cn", "clsx"]
}
